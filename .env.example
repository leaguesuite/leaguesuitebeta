# ──────────────────────────────────────────────
# League Suite Beta — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# Base URL of the API server.
# Default (Laravel): https://flagplusfootball.com
# For local ASP.NET Core: https://localhost:5001
VITE_API_BASE_URL=https://flagplusfootball.com

# Authentication mode: "cookie" (Laravel) or "bearer" (ASP.NET Core JWT)
VITE_AUTH_MODE=cookie

# Supabase (auto-managed by Lovable Cloud — normally leave blank)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
